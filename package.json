{
  "$schema": "https://www.schemastore.org/package.json",
  "name": "laravel-starter-kit",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "vite build",
    "dev": "vite",
    "typecheck": "vue-tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.php": [
      "docker compose exec -T app vendor/bin/pint --dirty --format agent --",
      "bash -c 'docker compose exec -T app vendor/bin/phpstan analyse --memory-limit=1G --no-progress'"
    ],
    "*.{ts,vue}": "bash -c 'docker compose exec -T app npm run typecheck'"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.0.0",
    "@vitest/coverage-v8": "^4.1.4",
    "@vue/test-utils": "^2.4.6",
    "axios": ">=1.11.0 <=1.14.0",
    "concurrently": "^9.0.1",
    "happy-dom": "^20.9.0",
    "husky": "^9.1.7",
    "laravel-vite-plugin": "^3.0.0",
    "lint-staged": "^16.4.0",
    "tailwindcss": "^4.0.0",
    "vite": "^8.0.0",
    "vitest": "^4.1.4"
  },
  "dependencies": {
    "@fullcalendar/core": "^6.1.20",
    "@fullcalendar/daygrid": "^6.1.20",
    "@fullcalendar/interaction": "^6.1.20",
    "@fullcalendar/timegrid": "^6.1.20",
    "@inertiajs/vue3": "^3.0.3",
    "@primevue/themes": "^4.5.4",
    "@vitejs/plugin-vue": "^6.0.5",
    "gsap": "^3.14.2",
    "laravel-echo": "^2.3.4",
    "mjml": "^5.0.1",
    "primeicons": "^7.0.0",
    "primevue": "^4.5.4",
    "pusher-js": "^8.5.0",
    "typescript": "^6.0.2",
    "vue": "^3.5.32",
    "vue-i18n": "^11.3.1",
    "vue-tsc": "^3.2.6"
  }
}
