APP_NAME="Ekstremedia Laravel Starter Kit"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://starter-kit.test
APP_HOST_PORT=80
VITE_HOST_PORT=5173
VITE_DEV_SERVER_HOST=starter-kit.test
VITE_APP_STORAGE_KEY=starter_kit_settings
VITE_APP_NAME="${APP_NAME}"

DEV_EASY_LOGIN_ENABLED=false

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=pgsql
DB_HOST=postgres
DB_PORT=5432
DB_DATABASE=starter
DB_USERNAME=starter
DB_PASSWORD=secret

SESSION_DRIVER=redis
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=reverb
FILESYSTEM_DISK=local

# Spatie Medialibrary — swap MEDIA_DISK to `s3` (or any other disk) to move
# uploaded media off the local filesystem. IMAGE_DRIVER=imagick (default) gives
# better quality and format support; fall back to `gd` if imagick isn't built.
MEDIA_DISK=public
IMAGE_DRIVER=imagick
QUEUE_CONVERSIONS_BY_DEFAULT=true
QUEUE_CONNECTION=redis

CACHE_STORE=redis

# Pulse uses Laravel's cache to memoize dashboard reads. Redis + phpredis can
# fail to rehydrate serialized Collections on subsequent polls, so Pulse is
# pinned to database cache by default. Switch to redis if your deployment
# uses predis or a Redis serializer that round-trips class names cleanly.
PULSE_CACHE_DRIVER=database

REDIS_CLIENT=phpredis
REDIS_HOST=redis
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=smtp
MAILPIT_HOST_PORT=8126
MAIL_SCHEME=null
MAIL_HOST=mailpit
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.test"
MAIL_FROM_NAME="${APP_NAME}"

STARTER_ADMIN_FIRST_NAME=Admin
STARTER_ADMIN_LAST_NAME=User
STARTER_ADMIN_EMAIL=admin@example.test
STARTER_ADMIN_PASSWORD=password

REVERB_APP_ID=starter-local
REVERB_APP_KEY=starter-local-key
REVERB_APP_SECRET=starter-local-secret
REVERB_HOST=127.0.0.1
REVERB_PORT=8080
REVERB_SCHEME=http
REVERB_SERVER_HOST=0.0.0.0
REVERB_SERVER_PORT=8080

# Browser websocket host. Keep this on your public local hostname, not 127.0.0.1.
VITE_REVERB_APP_KEY="${REVERB_APP_KEY}"
VITE_REVERB_HOST=starter-kit.test
VITE_REVERB_PORT="${REVERB_PORT}"
VITE_REVERB_SCHEME="${REVERB_SCHEME}"
